{
  "name": "akhchat",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @akhchat/db prisma generate",
    "db:migrate": "pnpm --filter @akhchat/db prisma migrate dev",
    "db:studio": "pnpm --filter @akhchat/db prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
